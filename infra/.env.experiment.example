# =============================================================================
# Experiment / Benchmark Environment Variables
# =============================================================================
# Sourced automatically by experiment scripts (run_oolong_benchmark.sh, etc.).
# Variables already set in the shell environment take precedence.
# This file is gitignored — add machine-specific paths here freely.
# =============================================================================

# Path to the cloned OOLONG repo (https://github.com/abertsch72/oolong).
# Used by benchmarks/oolong/scorer.py to import eval_helpers.py.
OOLONG_ROOT=/home/dlamagna/projects/oolong

# Agent A /task endpoint for standard benchmark runs.
# Default is http://localhost:8101/task if not set.
# AGENT_A_URL=http://localhost:8101/task

# -----------------------------------------------------------------------------
# [OOLONG] Benchmark settings
# -----------------------------------------------------------------------------

# Set OOLONG_WORKFLOW_URL to route tasks to an alternative workflow endpoint
# instead of /task.  The runner will POST each task to this URL.
# Examples:
#   OOLONG_WORKFLOW_URL=http://localhost:8101/agentverse   # 4-stage AgentVerse
#   OOLONG_WORKFLOW_URL=http://localhost:8101/task         # same as default
# Comment out to use the standard /task endpoint.
OOLONG_WORKFLOW_URL=http://localhost:8101/agentverse

# Label written to the 'scenario' field in JSONL output when OOLONG_WORKFLOW_URL
# is set.  Defaults to the URL path segment (e.g. "agentverse").
OOLONG_WORKFLOW_NAME=agentverse

# -----------------------------------------------------------------------------
# [OOLONG] AgentVerse-specific parameters
# Only used when OOLONG_WORKFLOW_URL points at /agentverse.
# -----------------------------------------------------------------------------

# Maximum number of AgentVerse iterations before giving up (default: 3, server cap: 5).
# OOLONG_AGENTVERSE_MAX_ITERATIONS=3

# Minimum evaluation score (0–100) to accept a result without retrying (default: 80).
# OOLONG_AGENTVERSE_SUCCESS_THRESHOLD=80

# -----------------------------------------------------------------------------
# [RLM] Recursive Language Model integration
# https://github.com/alexzhang13/rlm
# -----------------------------------------------------------------------------

# Host path to the cloned RLM repo.  Mounted read-only into agent-a at /rlm.
RLM_REPO_PATH=/home/dlamagna/projects/rlm

# RLM scenario for benchmark runs: rlm_simple | rlm_recursive | rlm_parallel
# rlm_simple    — single LLM call, no REPL (network baseline)
# rlm_recursive — REPL loop, LLM may issue recursive sub-calls and call Agent B
# rlm_parallel  — REPL loop, multiple named Agent B workers for fan-out
RLM_SCENARIO=rlm_recursive

# Maximum REPL recursion depth (ignored for rlm_simple).
# RLM_MAX_DEPTH=1

# Maximum REPL iterations per completion.
# RLM_MAX_ITERATIONS=30

# Optional cumulative token budget (0 = unlimited).
# RLM_MAX_TOKENS=0

# Optional wall-clock timeout in seconds (0 = unlimited).
# RLM_MAX_TIMEOUT=0
